# ---------------------------------------------------------------------------
# Storage and runtime data
# ---------------------------------------------------------------------------
storage/uploads/*
storage/processed/*
storage/outputs/*

# Keep the empty folders so the structure is preserved
!storage/uploads/.gitkeep
!storage/processed/.gitkeep
!storage/outputs/.gitkeep

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
build/
dist/
*.egg
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Environment files / secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.production
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Project local
# ---------------------------------------------------------------------------
*.bak
*.tmp
scratch/
notes/
